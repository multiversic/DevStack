# Exemple de variables d'environnement (Copiez ce fichier en .env)

# NEXTAUTH (Auth.js v5)
AUTH_SECRET="votre_secret_aleatoire_tres_long_et_complexe_ici"

# PRISMA / SUPABASE DATABASE
# Obtenez ces valeurs sur le dashboard Supabase de votre projet dans
# Project Settings > Database > Connection String (URI)
DATABASE_URL="postgres://postgres.[votre_ref]:[votre_password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://postgres.[votre_ref]:[votre_password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# RESEND (Pour les emails transactionnels)
RESEND_API_KEY="re_votre_cle_api_resend"

# API DEVISES (Open Exchange Rates)
OPEN_EXCHANGE_APP_ID="votre_cle_open_exchange"

# CRON SECRET (Pour sécuriser les routes cron Vercel)
CRON_SECRET="secret_pour_les_cron_jobs"
